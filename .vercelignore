# ── Python virtual environments ───────────────────────────────────────────────
backend/venv/
venv/
.venv/
env/
ENV/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# ── Node / Frontend (Vercel builds these itself) ───────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/

# ── Streamlit / legacy requirements (Vercel must ONLY use api/requirements.txt) ──
# Root requirements.txt was renamed to requirements-streamlit.txt so Vercel
# won't auto-discover it.  Do NOT add a blanket "requirements.txt" pattern
# here — it would also nuke api/requirements.txt which Vercel needs.
requirements-streamlit.txt
backend/requirements.txt

# ── Dev / OS files ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log
npm-debug.log*
.vscode/
.idea/
start_backend.bat
start_frontend.bat
