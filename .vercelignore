# ── Python virtual environments ───────────────────────────────────────────────
backend/venv/
venv/
.venv/
env/
ENV/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# ── Node / Frontend (Vercel builds these itself) ───────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/

